---
import MaterialIcon from './MaterialIcon.astro';
import { link } from '../../utils/link';

interface Lesson {
  title: string;
  slug: string;
}

interface Module {
  title: string;
  description: string;
  status: 'completed' | 'active' | 'future';
  lessons: Lesson[];
}

interface Props {
  modules: Module[];
  category: string;
  curriculum: string;
  activeModuleIndex?: number;
}

const { modules, category, curriculum, activeModuleIndex = 0 } = Astro.props;
---

<div class="relative space-y-md ml-xs lg:ml-0">
  {modules.map((mod, index) => {
    const isLast = index === modules.length - 1;
    const isActive = index === activeModuleIndex;
    const isCompleted = index < activeModuleIndex;
    const href = link(`/material/${category}/${curriculum}/${mod.lessons[0]?.slug || ''}`);
    
    return (
      <div class="relative flex gap-md items-start group">
        {!isLast && <div class="path-line" />}
        
        {/* Step Indicator */}
        <div class:list={[
          'relative z-10 w-8 h-8 rounded-full flex items-center justify-center shrink-0 mt-1',
          isCompleted 
            ? 'bg-surface-container-lowest border-2 border-primary-container'
            : isActive
              ? 'bg-surface-container-lowest border-2 border-primary-container shadow-[0_0_12px_rgba(61,220,132,0.3)]'
              : 'bg-surface-container-lowest border-2 border-outline-variant'
        ]}>
          {isCompleted && <span class="w-4 h-4 rounded-full bg-primary-container" />}
          {isActive && <span class="w-2 h-2 rounded-full bg-primary-container" />}
        </div>
        
        {/* Module Card - entire card is a link */}
        <a href={href} class:list={[
          'flex-1 bg-surface-container-lowest rounded-xl p-md transition-all block',
          isActive ? 'border-2 border-primary-container shadow-sm' : 'border border-outline-variant card-hover'
        ]}>
          <div class="flex justify-between items-center mb-sm">
            <h3 class="font-headline-md text-headline-md text-on-surface group-hover:text-primary transition-colors">{mod.title}</h3>
            <MaterialIcon name="bx-right-arrow-alt" class="text-on-surface-variant text-[20px]" />
          </div>
          <p class="font-body-md text-body-md text-on-surface-variant mb-0">{mod.description}</p>
        </a>
      </div>
    );
  })}
</div>

<style>
  .path-line {
    width: 2px;
    background-color: #E2E8F0;
    position: absolute;
    left: 15px;
    top: 32px;
    bottom: -32px;
    z-index: 0;
  }
  .card-hover:hover {
    border-color: #3DDC84;
    border-width: 2px;
    margin: -1px;
  }
</style>
