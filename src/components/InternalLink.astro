---
// Helper component untuk internal links yang otomatis menambahkan BASE_URL
interface Props {
  href: string;
  class?: string;
}

const { href, class: className = '', ...props } = Astro.props;

function resolveUrl(url: string): string {
  // External links: return as-is
  if (url.startsWith('http://') || url.startsWith('https://') || url.startsWith('mailto:') || url.startsWith('tel:')) {
    return url;
  }
  
  const base = import.meta.env.BASE_URL;
  
  // Already has base URL
  if (url.startsWith(base)) {
    return url;
  }
  
  // Starts with /: prepend base
  if (url.startsWith('/')) {
    return base + url.slice(1);
  }
  
  // Relative or hash-only
  return url;
}

const resolvedHref = resolveUrl(href);
---

<a href={resolvedHref} class={className} {...props}>
  <slot />
</a>
