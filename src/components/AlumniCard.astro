---
interface Alumni {
  id: string;
  name: string;
  role: string;
  batch: number;
  photo?: string;
  consent: boolean;
  currentPosition?: string;
  contact?: {
    email?: string;
    linkedin?: string;
  };
  achievements?: string[];
}

interface Props {
  alumni: Alumni;
}

const { alumni } = Astro.props;

const roleStyles: Record<string, string> = {
  'Ketua': 'bg-on-background text-white',
  'Wakil Ketua': 'bg-secondary text-white',
  'Sekretaris': 'bg-primary text-white',
  'Bendahara': 'bg-tertiary text-white',
  'Pengurus': 'bg-surface-variant text-on-background',
  'Anggota': 'bg-surface-container text-on-background',
};

const defaultAvatar = `https://api.dicebear.com/7.x/initials/svg?seed=${encodeURIComponent(alumni.name)}&backgroundColor=4CAF50&textColor=ffffff`;
---

<article class="group bg-white border border-surface-border overflow-hidden rounded hover:border-primary transition-colors duration-300">
  <div class="aspect-square overflow-hidden bg-surface-container">
    {alumni.consent === false ? (
      <div class="w-full h-full flex items-center justify-center bg-surface-container">
        <i class="bx bx-user-x text-surface-border text-[64px]"></i>
      </div>
    ) : (
      <img
        src={alumni.photo || defaultAvatar}
        alt={alumni.name}
        class="w-full h-full object-cover"
        loading="lazy"
        onerror={`this.src='${defaultAvatar}'`}
      />
    )}
  </div>
  
  <div class="p-4">
    <div class="flex items-center gap-2 mb-2">
      <span class:list={[
        'px-2 py-1 font-label-md text-label-md uppercase tracking-widest',
        roleStyles[alumni.role] || 'bg-surface-variant text-on-background'
      ]}>
        {alumni.role}
      </span>
    </div>
    
    <h3 class="text-headline-md text-on-background mb-1">{alumni.name}</h3>
    
    {alumni.currentPosition && (
      <p class="text-secondary text-body-md mb-3 line-clamp-2">{alumni.currentPosition}</p>
    )}
    
    {alumni.achievements && alumni.achievements.length > 0 && (
      <div class="space-y-1 mb-3">
        {alumni.achievements.slice(0, 2).map((achievement) => (
          <div class="flex items-start gap-2 text-body-md text-secondary">
            <i class="bx bx-check text-primary text-[14px] mt-0.5 flex-shrink-0"></i>
            <span class="line-clamp-1">{achievement}</span>
          </div>
        ))}
      </div>
    )}
    
    {alumni.contact && (alumni.contact.email || alumni.contact.linkedin) && (
      <div class="flex items-center gap-2 pt-3 border-t border-surface-border">
        {alumni.contact.linkedin && (
          <a
            href={alumni.contact.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="p-2 text-secondary hover:text-primary hover:bg-surface-container transition-colors"
            aria-label={`${alumni.name}'s LinkedIn`}
          >
            <i class="bx bxl-linkedin text-[16px]"></i>
          </a>
        )}
        {alumni.contact.email && (
          <a
            href={`mailto:${alumni.contact.email}`}
            class="p-2 text-secondary hover:text-primary hover:bg-surface-container transition-colors"
            aria-label={`Email ${alumni.name}`}
          >
            <i class="bx bx-envelope text-[16px]"></i>
          </a>
        )}
      </div>
    )}
  </div>
</article>

<style>
  .line-clamp-1 {
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
