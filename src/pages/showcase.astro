---
import Layout from '../layouts/Layout.astro';
import { link } from '../utils/link';

const projects = [
  {
    id: 1,
    title: "E-Commerce Mobile App Redesign",
    description: "Complete UI/UX redesign for a local e-commerce platform focusing on improving user experience and conversion rates through modern design principles.",
    type: "design",
    url: "https://figma.com/example-ecommerce",
    author: "Sarah Wijaya",
    batch: "2022",
    image: "/images/showcase/ecommerce-design.jpg"
  },
  {
    id: 2,
    title: "Task Management API",
    description: "RESTful API built with Node.js and Express for managing tasks and projects. Features authentication, real-time updates, and comprehensive documentation.",
    type: "code",
    url: "https://github.com/example/task-api",
    author: "Ahmad Fauzi",
    batch: "2023",
    image: "/images/showcase/task-api.jpg"
  },
  {
    id: 3,
    title: "Healthcare Dashboard Design",
    description: "Modern dashboard design for healthcare management system with data visualization, patient tracking, and appointment scheduling features.",
    type: "design",
    url: "https://figma.com/example-healthcare",
    author: "Maya Putri",
    batch: "2021",
    image: "/images/showcase/healthcare-dashboard.jpg"
  },
  {
    id: 4,
    title: "Social Media Analytics Tool",
    description: "Python-based analytics tool for tracking social media metrics across multiple platforms. Includes data visualization and automated reporting.",
    type: "code",
    url: "https://github.com/example/social-analytics",
    author: "Reza Pratama",
    batch: "2022",
    image: "/images/showcase/analytics-tool.jpg"
  },
  {
    id: 5,
    title: "Banking App UI Kit",
    description: "Comprehensive UI kit for banking applications including 50+ screens, design system, and component library for rapid prototyping.",
    type: "design",
    url: "https://figma.com/example-banking-kit",
    author: "Dewi Anggraini",
    batch: "2023",
    image: "/images/showcase/banking-kit.jpg"
  },
  {
    id: 6,
    title: "Weather Forecast App",
    description: "Flutter weather application with real-time data, location services, and beautiful animations. Integrates with OpenWeatherMap API.",
    type: "code",
    url: "https://github.com/example/weather-app",
    author: "Budi Santoso",
    batch: "2021",
    image: "/images/showcase/weather-app.jpg"
  }
];

const designProjects = projects.filter(p => p.type === 'design');
const codeProjects = projects.filter(p => p.type === 'code');

const typeBadgeStyles: Record<string, string> = {
  'design': 'bg-primary text-white',
  'code': 'bg-secondary text-white',
};
---

<Layout title="Showcase - Komandro CCIT-FTUI"
  description="Showcase of amazing projects by Komandro alumni. Discover innovative designs and code repositories from our talented community members.">
  <main class="pt-24">
    
    <!-- Hero Section -->
    <section class="relative overflow-hidden bg-white hero-pattern border-b border-surface-border">
      <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-32">
        <div class="max-w-4xl">
          <div class="inline-flex items-center gap-3 border border-surface-border px-4 py-2 bg-white rounded-sm mb-10">
            <span class="w-2 h-2 bg-primary"></span>
            <span class="text-secondary font-label-md text-label-md uppercase tracking-widest">Projects</span>
          </div>
          <h1 class="text-headline-xl-home-mobile md:text-headline-xl-home text-on-background mb-6 leading-tight">
            Project <span class="text-primary">Showcase</span>
          </h1>
          <p class="text-body-lg-home text-secondary max-w-2xl leading-relaxed">
            Amazing projects by Komandro alumni. Discover innovative designs and code repositories from our talented community.
          </p>
        </div>
      </div>
    </section>

    <!-- Filter Stats -->
    <section class="py-16 bg-surface-container-low border-b border-surface-border">
      <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="flex items-center gap-4">
            <i class="bx bx-palette text-on-background text-[32px]"></i>
            <div>
              <div class="text-headline-md-home text-on-background">{designProjects.length}</div>
              <div class="font-label-md text-label-md text-secondary uppercase tracking-widest">Design Projects</div>
            </div>
          </div>
          
          <div class="flex items-center gap-4">
            <i class="bx bx-code-alt text-on-background text-[32px]"></i>
            <div>
              <div class="text-headline-md-home text-on-background">{codeProjects.length}</div>
              <div class="font-label-md text-label-md text-secondary uppercase tracking-widest">Code Projects</div>
            </div>
          </div>
          
          <div class="flex items-center gap-4">
            <i class="bx bx-collection text-on-background text-[32px]"></i>
            <div>
              <div class="text-headline-md-home text-on-background">{projects.length}</div>
              <div class="font-label-md text-label-md text-secondary uppercase tracking-widest">Total Projects</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Design Projects Section -->
    {designProjects.length > 0 && (
      <section class="py-32 bg-white border-b border-surface-border">
        <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
          <div class="flex items-center gap-4 mb-12">
            <i class="bx bx-palette text-on-background text-[28px]"></i>
            <h2 class="text-headline-lg-home text-on-background">Design Projects</h2>
            <div class="flex-1 h-px bg-surface-border"></div>
            <span class="px-3 py-1 bg-primary text-white font-label-md text-label-md uppercase tracking-widest">
              UI/UX
            </span>
          </div>

          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            {designProjects.map((project) => (
              <a
                href={project.url}
                target="_blank"
                rel="noopener noreferrer"
                class="group bg-white border border-surface-border overflow-hidden rounded hover:border-primary transition-colors duration-300"
              >
                <div class="aspect-video bg-surface-container relative overflow-hidden">
                  {project.image ? (
                    <img 
                      src={project.image} 
                      alt={project.title}
                      class="w-full h-full object-cover"
                    />
                  ) : (
                    <div class="w-full h-full flex items-center justify-center">
                      <i class="bx bx-image text-surface-border text-[48px]"></i>
                    </div>
                  )}
                  
                  <div class="absolute top-3 right-3">
                    <span class="px-3 py-1 bg-primary text-white font-label-md text-label-md uppercase tracking-widest">
                      Design
                    </span>
                  </div>
                </div>
                
                <div class="p-6">
                  <h3 class="text-headline-md text-on-background mb-2 group-hover:text-primary transition-colors line-clamp-1">
                    {project.title}
                  </h3>
                  
                  <p class="text-secondary text-body-md mb-6 line-clamp-3">
                    {project.description}
                  </p>
                  
                  <div class="flex items-center justify-between pt-4 border-t border-surface-border">
                    <div class="flex items-center gap-3">
                      <div class="w-8 h-8 bg-surface-container flex items-center justify-center text-on-background text-xs font-bold">
                        {project.author.charAt(0)}
                      </div>
                      <div class="text-body-md">
                        <div class="text-on-background font-medium">{project.author}</div>
                        <div class="text-secondary">Batch {project.batch}</div>
                      </div>
                    </div>
                    
                    <span class="inline-flex items-center gap-1 text-primary opacity-0 group-hover:opacity-100 transition-opacity font-label-md text-label-md uppercase tracking-wider">
                      View
                      <i class="bx bx-right-arrow-alt text-[14px]"></i>
                    </span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Code Projects Section -->
    {codeProjects.length > 0 && (
      <section class="py-32 bg-surface-container-low border-b border-surface-border">
        <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
          <div class="flex items-center gap-4 mb-12">
            <i class="bx bx-code-alt text-on-background text-[28px]"></i>
            <h2 class="text-headline-lg-home text-on-background">Code Projects</h2>
            <div class="flex-1 h-px bg-surface-border"></div>
            <span class="px-3 py-1 bg-secondary text-white font-label-md text-label-md uppercase tracking-widest">
              GitHub
            </span>
          </div>

          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            {codeProjects.map((project) => (
              <a
                href={project.url}
                target="_blank"
                rel="noopener noreferrer"
                class="group bg-white border border-surface-border overflow-hidden rounded hover:border-primary transition-colors duration-300"
              >
                <div class="aspect-video bg-slate-dark relative overflow-hidden">
                  {project.image ? (
                    <img 
                      src={project.image} 
                      alt={project.title}
                      class="w-full h-full object-cover"
                    />
                  ) : (
                    <div class="w-full h-full flex items-center justify-center">
                      <i class="bx bx-code-block text-white/30 text-[48px]"></i>
                    </div>
                  )}
                  
                  <div class="absolute top-3 right-3">
                    <span class="px-3 py-1 bg-secondary text-white font-label-md text-label-md uppercase tracking-widest">
                      Code
                    </span>
                  </div>
                </div>
                
                <div class="p-6">
                  <h3 class="text-headline-md text-on-background mb-2 group-hover:text-primary transition-colors line-clamp-1">
                    {project.title}
                  </h3>
                  
                  <p class="text-secondary text-body-md mb-6 line-clamp-3">
                    {project.description}
                  </p>
                  
                  <div class="flex items-center justify-between pt-4 border-t border-surface-border">
                    <div class="flex items-center gap-3">
                      <div class="w-8 h-8 bg-surface-container flex items-center justify-center text-on-background text-xs font-bold">
                        {project.author.charAt(0)}
                      </div>
                      <div class="text-body-md">
                        <div class="text-on-background font-medium">{project.author}</div>
                        <div class="text-secondary">Batch {project.batch}</div>
                      </div>
                    </div>
                    
                    <span class="inline-flex items-center gap-1 text-primary opacity-0 group-hover:opacity-100 transition-opacity font-label-md text-label-md uppercase tracking-wider">
                      GitHub
                      <i class="bx bx-right-arrow-alt text-[14px]"></i>
                    </span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Update Schedule Info -->
    <section class="py-32 bg-white">
      <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
        <div class="border border-surface-border rounded p-8 md:p-16 text-center">
          <i class="bx bx-time text-on-background text-[48px] mb-6"></i>
          <h2 class="text-headline-lg-home text-on-background mb-4">Regular Updates</h2>
          <div class="w-24 h-1 bg-primary mx-auto mb-8"></div>
          <p class="text-body-lg-home text-secondary max-w-2xl mx-auto leading-relaxed">
            Projects are updated at the end of each batch period. Stay tuned for new showcases from every graduating class!
          </p>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .line-clamp-1 {
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
