---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { link } from '../../utils/link';

const posts = await getCollection('blog', ({ data }) => {
  return data.draft !== true;
});

const sortedPosts = posts.sort((a, b) => 
  new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);
---

<Layout title="Blog - Komandro CCIT-FTUI">
  <main class="pt-24">
    
    <!-- Hero Section -->
    <section class="relative overflow-hidden bg-white hero-pattern border-b border-surface-border">
      <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-32">
        <div class="max-w-4xl">
          <div class="inline-flex items-center gap-3 border border-surface-border px-4 py-2 bg-white rounded-sm mb-10">
            <span class="w-2 h-2 bg-primary"></span>
            <span class="text-secondary font-label-md text-label-md uppercase tracking-widest">Publications</span>
          </div>
          <h1 class="text-headline-xl-home-mobile md:text-headline-xl-home text-on-background mb-6 leading-tight">
            <span class="text-primary">Blog</span>
          </h1>
          <p class="text-body-lg-home text-secondary max-w-2xl leading-relaxed">
            News, updates, and insights from the Komandro community.
          </p>
        </div>
      </div>
    </section>

    <!-- Blog Posts -->
    <section class="py-32 bg-white">
      <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
        {sortedPosts.length === 0 ? (
          <div class="text-center py-24 border border-surface-border rounded">
            <div class="mb-6">
              <i class="bx bx-file-blank text-surface-border text-[64px]"></i>
            </div>
            <h2 class="text-headline-md text-on-background mb-2">No Posts Yet</h2>
            <p class="text-secondary text-body-md">Blog posts will be published soon!</p>
          </div>
        ) : (
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            {sortedPosts.map((post) => (
              <article class="group bg-white border-0 md:border border-surface-border overflow-hidden rounded-none md:rounded hover:border-primary transition-colors duration-300">
                {post.data.heroImage && (
                  <div class="aspect-video overflow-hidden bg-surface-container">
                    <img 
                      src={post.data.heroImage} 
                      alt={post.data.title}
                      class="w-full h-full object-cover"
                      loading="lazy"
                    />
                  </div>
                )}
                
                <div class="p-6">
                  <div class="flex items-center gap-3 mb-4 font-label-md text-label-md text-secondary uppercase tracking-widest">
                    <span>{new Date(post.data.pubDate).toLocaleDateString('id-ID', { 
                      year: 'numeric', 
                      month: 'short', 
                      day: 'numeric' 
                    })}</span>
                    <span class="w-1 h-1 bg-secondary" />
                    <span>{post.data.author}</span>
                  </div>

                  <a href={link(`/blog/${post.slug}`)}>
                    <h2 class="text-headline-md text-on-background mb-3 group-hover:text-primary transition-colors">
                      {post.data.title}
                    </h2>
                  </a>

                  <p class="text-secondary text-body-md mb-6 line-clamp-2">{post.data.description}</p>

                  <a 
                    href={link(`/blog/${post.slug}`)} 
                    class="inline-flex items-center gap-2 text-on-background font-label-md text-label-md uppercase tracking-wider hover:text-primary transition-colors group/link"
                  >
                    Read More
                    <i class="bx bx-right-arrow-alt text-[16px] group-hover/link:translate-x-1 transition-transform"></i>
                  </a>
                </div>
              </article>
            ))}
          </div>
        )}
      </div>
    </section>
  </main>
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
