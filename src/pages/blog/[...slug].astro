---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<Layout title={`${post.data.title} - Komandro CCIT-FTUI`}>
  <main class="min-h-screen bg-slate-50">
    
    <!-- Hero Section -->
    <section class="bg-gradient-to-br from-[#4CAF50] to-[#3DDC84] text-white py-12 px-4">
      <div class="max-w-4xl mx-auto">
        <a href="/blog" class="inline-flex items-center gap-2 text-white/80 hover:text-white mb-6 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m15 18-6-6 6-6"/>
          </svg>
          Back to Blog
        </a>
        
        <div class="flex flex-wrap items-center gap-4 mb-6 text-sm">
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect width="18" height="18" x="3" y="4" rx="2" ry="2"/>
              <line x1="16" x2="16" y1="2" y2="6"/>
              <line x1="8" x2="8" y1="2" y2="6"/>
              <line x1="3" x2="21" y1="10" y2="10"/>
            </svg>
            {new Date(post.data.pubDate).toLocaleDateString('id-ID', { 
              year: 'numeric', 
              month: 'long', 
              day: 'numeric' 
            })}
          </div>
          
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/>
              <circle cx="12" cy="7" r="4"/>
            </svg>
            {post.data.author}
          </div>
        </div>
        
        <h1 class="text-3xl md:text-4xl font-bold">{post.data.title}</h1>
      </div>
    </section>

    <!-- Content -->
    <section class="py-12 px-4">
      <div class="max-w-4xl mx-auto">
        <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden">
          {post.data.heroImage && (
            <div class="aspect-video">
              <img 
                src={post.data.heroImage} 
                alt={post.data.title}
                class="w-full h-full object-cover"
              />
            </div>
          )}
          
          <div class="p-8 md:p-12">
            <p class="text-xl text-gray-600 mb-8">{post.data.description}</p>

            <article class="prose prose-lg max-w-none prose-headings:text-gray-800 prose-p:text-gray-600 prose-a:text-[#4CAF50] prose-a:no-underline hover:prose-a:underline prose-strong:text-gray-800 prose-code:text-[#4CAF50] prose-code:bg-gray-100 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded">
              <Content />
            </article>

            {post.data.tags && post.data.tags.length > 0 && (
              <div class="mt-12 pt-8 border-t border-gray-200">
                <h3 class="text-sm font-semibold text-gray-500 mb-3">Tags</h3>
                <div class="flex flex-wrap gap-2">
                  {post.data.tags.map((tag) => (
                    <span class="px-3 py-1 bg-gray-100 text-gray-700 rounded-full text-sm">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
            )}

            {post.data.updatedDate && (
              <div class="mt-6 text-sm text-gray-500">
                Updated: {new Date(post.data.updatedDate).toLocaleDateString('id-ID', { 
                  year: 'numeric', 
                  month: 'long', 
                  day: 'numeric' 
                })}
              </div>
            )}
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style is:global>
  /* Shiki already handles pre/code styling with inline styles */
  
  .prose img {
    border-radius: 0.5rem;
    border: 1px solid #e5e7eb;
  }
  
  .prose blockquote {
    border-left-color: #4CAF50;
    background-color: #f8fafc;
    padding: 1rem 1.5rem;
    border-radius: 0 0.5rem 0.5rem 0;
  }
</style>
