---
import Layout from '../../layouts/Layout.astro';
import { link } from '../../utils/link';

const currentYear = new Date().getFullYear();
const maxBatchYear = currentYear - 2;
const availableYears = Array.from({ length: maxBatchYear - 2014 }, (_, i) => 2015 + i).reverse();

const getYearDescription = (year: number): string => {
  if (year === 2015) return 'Founding Year';
  if (year === maxBatchYear) return 'Latest Batch';
  return `Batch ${year - 2014}`;
};
---

<Layout title="Alumni - Komandro CCIT-FTUI">
  <main class="pt-24">
    
    <!-- Hero Section -->
    <section class="relative overflow-hidden bg-white hero-pattern border-b border-surface-border">
      <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-32">
        <div class="max-w-4xl">
          <h1 class="text-headline-xl-home-mobile md:text-headline-xl-home text-on-background mb-6 leading-tight">
            Alumni <span class="text-primary">Directory</span>
          </h1>
          <p class="text-body-lg-home text-secondary mb-12 max-w-2xl leading-relaxed">
            Explore our {availableYears.length} batches of talented alumni who have shaped Komandro's journey since 2015.
          </p>
        </div>
      </div>
    </section>

    <!-- Featured Alumni -->
    <section class="py-32 bg-surface-container-low border-b border-surface-border">
      <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
        <div class="mb-20 text-center">
          <div class="inline-flex items-center gap-3 border border-surface-border px-4 py-2 bg-white mb-10">
            <span class="w-2 h-2 bg-primary"></span>
            <span class="text-secondary font-label-md text-label-md uppercase tracking-widest">Hall of Fame</span>
          </div>
          <h2 class="text-headline-lg-home text-on-background mb-6">Featured Alumni</h2>
          <div class="w-24 h-1 bg-primary mx-auto mb-8"></div>
          <p class="text-secondary max-w-xl mx-auto text-body-lg-home leading-relaxed">
            Alumni who have made significant impact on the Komandro community.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <!-- Hudya -->
          <div class="bg-white border border-surface-border rounded p-8 text-center hover:border-primary transition-colors duration-300">
            <div class="w-20 h-20 mx-auto mb-6 rounded-full bg-primary/10 flex items-center justify-center">
              <span class="text-primary text-headline-lg font-bold">HR</span>
            </div>
            <h3 class="text-headline-md text-on-background mb-1">Muhamad Hudya Ramadhana</h3>
            <p class="text-primary font-label-md text-label-md uppercase tracking-widest mb-4">Lead Backend Engineer</p>
            <p class="text-secondary text-body-md">Batch 2015</p>
            <a href="https://linkedin.com/in/perogeremmer" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 mt-4 text-secondary hover:text-primary transition-colors font-label-md text-label-md">
              <i class="bx bxl-linkedin text-[16px]"></i>
              LinkedIn
            </a>
          </div>

          <!-- Natasha -->
          <div class="bg-white border border-surface-border rounded p-8 text-center hover:border-primary transition-colors duration-300">
            <div class="w-20 h-20 mx-auto mb-6 rounded-full bg-primary/10 flex items-center justify-center">
              <span class="text-primary text-headline-lg font-bold">NS</span>
            </div>
            <h3 class="text-headline-md text-on-background mb-1">Natasha Syeikinah Marsauli</h3>
            <p class="text-primary font-label-md text-label-md uppercase tracking-widest mb-4">Product Manager</p>
            <p class="text-secondary text-body-md">Batch 2018</p>
            <a href="https://www.linkedin.com/in/natassm/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 mt-4 text-secondary hover:text-primary transition-colors font-label-md text-label-md">
              <i class="bx bxl-linkedin text-[16px]"></i>
              LinkedIn
            </a>
          </div>

          <!-- Tivo -->
          <div class="bg-white border border-surface-border rounded p-8 text-center hover:border-primary transition-colors duration-300">
            <div class="w-20 h-20 mx-auto mb-6 rounded-full bg-primary/10 flex items-center justify-center">
              <span class="text-primary text-headline-lg font-bold">TY</span>
            </div>
            <h3 class="text-headline-md text-on-background mb-1">Tivo Yudha Perwira</h3>
            <p class="text-primary font-label-md text-label-md uppercase tracking-widest mb-4">Lead Frontend Engineer</p>
            <p class="text-secondary text-body-md">Batch 2015</p>
            <a href="https://www.linkedin.com/in/tivo-yudha/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 mt-4 text-secondary hover:text-primary transition-colors font-label-md text-label-md">
              <i class="bx bxl-linkedin text-[16px]"></i>
              LinkedIn
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Year Grid -->
    <section class="py-32 bg-white border-b border-surface-border">
      <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
        <div class="mb-20">
          <h2 class="text-headline-lg-home text-on-background mb-6">Select a Batch Year</h2>
          <div class="w-24 h-1 bg-primary mb-8"></div>
          <p class="text-secondary max-w-xl text-body-lg-home leading-relaxed">
            Click on any year to view the alumni who were part of that batch.
          </p>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-6">
          {availableYears.map((year) => (
            <a
              href={link(`/alumni/${year}`)}
              class="group bg-white border border-surface-border rounded p-6 text-center hover:border-primary transition-colors duration-300"
            >
              <div class="mb-4">
                <i class="bx bx-calendar text-on-background text-[32px] group-hover:text-primary transition-colors"></i>
              </div>
              
              <div class="text-headline-lg text-on-background mb-1">{year}</div>
              
              <div class="font-label-md text-label-md text-secondary uppercase tracking-widest">{getYearDescription(year)}</div>
              
              <div class="mt-4 inline-flex items-center gap-1 text-primary opacity-0 group-hover:opacity-100 transition-opacity font-label-md text-label-md uppercase tracking-wider">
                <span>View</span>
                <i class="bx bx-right-arrow-alt text-[14px]"></i>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Study Turtle Section -->
    <section class="py-32 bg-surface-container-low border-b border-surface-border">
      <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
        <div class="flex flex-col lg:flex-row justify-between items-start gap-16">
          <div class="lg:w-1/2">
          <div class="inline-flex items-center gap-3 border border-surface-border px-4 py-2 bg-white rounded-sm mb-10">
              <span class="w-2 h-2 bg-primary"></span>
              <span class="text-secondary font-label-md text-label-md uppercase tracking-widest">Alumni Program</span>
            </div>
            <h2 class="text-headline-lg-home text-on-background mb-6">Study Turtle (Stutle)</h2>
            <div class="w-24 h-1 bg-primary mb-8"></div>
            <p class="text-secondary text-body-md leading-relaxed mb-4">
              All alumni who graduated from CCIT-FTUI and former Komandro members automatically 
              become part of Study Turtle (Stutle) — an exclusive alumni organization dedicated 
              to continuous growth and professional development.
            </p>
            <p class="text-secondary text-body-md leading-relaxed mb-8">
              Stutle provides comprehensive programs designed to enhance the capabilities of 
              Komandro alumni in the professional world, including one-on-one mentoring, 
              career coaching, networking opportunities, and industry workshops.
            </p>
            <a 
            href={link('/alumni/2015')} 
            class="inline-flex items-center gap-2 bg-on-background text-white px-8 py-4 rounded font-label-md text-label-md uppercase tracking-wider hover:bg-primary hover:text-white transition-colors duration-300"
            >
              Explore Alumni Network
              <i class="bx bx-right-arrow-alt text-[20px]"></i>
            </a>
          </div>
          
          <div class="lg:w-1/2 flex items-center justify-center">
            <div class="border border-surface-border bg-white rounded p-12 w-full max-w-md aspect-square flex items-center justify-center">
              <div class="text-center">
                <i class="bx bx-group text-surface-border text-[80px] mb-6"></i>
                <div class="text-headline-lg text-on-background mb-2">Study Turtle</div>
                <div class="text-secondary text-body-md mb-1">Alumni Organization</div>
                <div class="text-secondary text-body-md">Mentoring &bull; Growth &bull; Success</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
