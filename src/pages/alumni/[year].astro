---
import type { GetStaticPaths } from 'astro';
import Layout from '../../layouts/Layout.astro';
import AlumniCard from '../../components/AlumniCard.astro';
import { link } from '../../utils/link';

interface Alumni {
  id: string;
  name: string;
  role: string;
  batch: number;
  photo?: string;
  consent: boolean;
  currentPosition?: string;
  contact?: {
    email?: string;
    linkedin?: string;
  };
  achievements?: string[];
}

export const getStaticPaths: GetStaticPaths = async () => {
  const alumniFiles = import.meta.glob('/src/data/alumni/*.json', { eager: true });
  
  const paths = Object.entries(alumniFiles).map(([path, data]) => {
    const yearMatch = path.match(/(\d{4})\.json$/);
    if (!yearMatch) return null;
    
    const year = yearMatch[1];
    const alumniData = data as { default: Alumni[] };
    
    return {
      params: { year },
      props: {
        year: parseInt(year),
        alumni: alumniData.default || alumniData
      }
    };
  }).filter(Boolean);
  
  return paths;
};

interface Props {
  year: number;
  alumni: Alumni[];
}

const { year, alumni } = Astro.props;

const sortedAlumni = [...alumni].sort((a, b) => {
  const roleOrder = ['Ketua', 'Wakil Ketua', 'Sekretaris', 'Bendahara', 'Pengurus', 'Anggota'];
  const aIndex = roleOrder.indexOf(a.role);
  const bIndex = roleOrder.indexOf(b.role);
  return aIndex - bIndex;
});

const currentYear = new Date().getFullYear();
const availableYears = Array.from({ length: currentYear - 2014 }, (_, i) => 2015 + i).reverse();
---

<Layout title={`Alumni Batch ${year} - Komandro CCIT-FTUI`}>
  <main class="pt-24">
    <!-- Hero Section -->
    <section class="relative overflow-hidden bg-white hero-pattern border-b border-surface-border">
      <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-32">
        <div class="max-w-4xl">
          <a href={link('/alumni')} class="inline-flex items-center gap-2 text-secondary hover:text-on-background mb-6 font-label-md text-label-md uppercase tracking-wider transition-colors">
            <i class="bx bx-left-arrow-alt text-[18px]"></i>
            Back to Alumni
          </a>
          <h1 class="text-headline-xl-home-mobile md:text-headline-xl-home text-on-background mb-6 leading-tight">
            Alumni Batch <span class="text-primary">{year}</span>
          </h1>
          <p class="text-body-lg-home text-secondary max-w-2xl leading-relaxed">
            Meet the talented members who shaped Komandro CCIT-FTUI in {year}.
          </p>
        </div>
      </div>
    </section>

    <!-- Year Navigation -->
    <section class="bg-white border-b border-surface-border py-4 sticky top-24 z-40">
      <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
        <div class="flex items-center gap-2 overflow-x-auto pb-2 scrollbar-hide">
          <span class="font-label-md text-label-md text-secondary uppercase tracking-widest whitespace-nowrap mr-4">
            Filter by Year:
          </span>
          {availableYears.map((yr) => (
            <a
              href={link(`/alumni/${yr}`)}
              class:list={[
                'px-4 py-2 font-label-md text-label-md uppercase tracking-wider whitespace-nowrap transition-colors border-b-2',
                yr === year
                  ? 'text-on-background font-bold border-primary'
                  : 'text-secondary border-transparent hover:text-on-background hover:border-surface-border'
              ]}
            >
              {yr}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Alumni Grid -->
    <section class="py-16 px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
      <div class="flex items-center justify-between mb-12">
        <div>
          <h2 class="text-headline-lg-home text-on-background">
            {alumni.length} Member{alumni.length !== 1 ? 's' : ''}
          </h2>
          <p class="text-secondary text-body-md">The {year} generation</p>
        </div>
      </div>

      {alumni.length === 0 ? (
        <div class="text-center py-24 bg-white border border-surface-border rounded">
          <div class="mb-6">
            <i class="bx bx-user-x text-surface-border text-[64px]"></i>
          </div>
          <h3 class="text-headline-md text-on-background mb-2">No Alumni Data</h3>
          <p class="text-secondary text-body-md max-w-md mx-auto">
            No alumni records found for batch {year}. The data might not be available yet.
          </p>
        </div>
      ) : (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
          {sortedAlumni.map((person) => (
            <AlumniCard 
              alumni={person}
            />
          ))}
        </div>
      )}
    </section>

    <!-- Join CTA -->
    <section class="py-32 bg-on-background text-white">
      <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop text-center">
        <h2 class="text-headline-lg-home mb-6">Be Part of Our Story</h2>
        <div class="w-24 h-1 bg-primary mx-auto mb-8"></div>
        <p class="text-body-lg-home text-white/70 mb-12 max-w-2xl mx-auto leading-relaxed">
          Join Komandro CCIT-FTUI and become the next generation of tech leaders.
        </p>
        <a 
          href={link('/')} 
          class="inline-flex items-center gap-2 bg-white text-on-background px-8 py-4 rounded font-label-md text-label-md uppercase tracking-wider hover:bg-primary hover:text-white transition-colors duration-300"
        >
          Join Us Today
          <i class="bx bx-right-arrow-alt text-[20px]"></i>
        </a>
      </div>
    </section>
  </main>
</Layout>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
