---
import Layout from '../layouts/Layout.astro';

const currentYear = new Date().getFullYear();

const milestones = [
  { year: 2015, title: 'Founded', description: 'Komandro CCIT-FTUI was established by a group of passionate students.' },
  { year: 2016, title: 'First Workshop', description: 'Organized the first Android development workshop on campus.' },
  { year: 2018, title: 'Expanded Scope', description: 'Added Backend, Frontend, and DevOps to our learning tracks.' },
  { year: 2020, title: 'Online Transition', description: 'Successfully transitioned to online learning during the pandemic.' },
  { year: 2022, title: '1000+ Members', description: 'Reached over 1000 registered members across all batches.' },
  { year: currentYear, title: 'Continuous Growth', description: 'Continuing to evolve and adapt to new technologies.' },
];

const team = [
  { role: 'Ketua', name: 'Ahmad Fauzi', period: '2024', current: true },
  { role: 'Wakil Ketua', name: 'Nurul Aisyah', period: '2024', current: true },
  { role: 'Sekretaris', name: 'Rina Wulandari', period: '2024', current: true },
  { role: 'Bendahara', name: 'Dika Pratama', period: '2024', current: true },
];
---

<Layout title="About - Komandro CCIT-FTUI">
  <main class="min-h-screen bg-slate-50">
    
    <!-- Hero Section -->
    <section class="bg-gradient-to-br from-[#4CAF50] to-[#3DDC84] text-white py-20 px-4">
      <div class="max-w-6xl mx-auto text-center">
        <div class="w-20 h-20 mx-auto bg-white/20 rounded-full flex items-center justify-center mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <path d="M12 16v-4"/>
            <path d="M12 8h.01"/>
          </svg>
        </div>
        
        <h1 class="text-4xl md:text-5xl font-bold mb-4">About Komandro</h1>
        
        <p class="text-xl text-white/90 max-w-2xl mx-auto">
          Learn about our journey, mission, and the community we've built since 2015
        </p>
      </div>
    </section>

    <!-- Mission & Vision -->
    <section class="py-16 px-4">
      <div class="max-w-6xl mx-auto">
        <div class="grid md:grid-cols-2 gap-12">
          <div class="bg-white rounded-2xl p-8 border border-gray-200">
            <div class="w-14 h-14 bg-[#4CAF50]/10 rounded-xl flex items-center justify-center mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#4CAF50" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/>
                <circle cx="12" cy="12" r="3"/>
              </svg>
            </div>
            
            <h2 class="text-2xl font-bold text-gray-800 mb-4">Our Mission</h2>
            
            <p class="text-gray-600 leading-relaxed">
              To foster a collaborative learning environment where students can develop 
              technical skills in Android development and modern technologies, while 
              building lasting professional networks and contributing to the tech community.
            </p>
          </div>
          
          <div class="bg-white rounded-2xl p-8 border border-gray-200">
            <div class="w-14 h-14 bg-[#4CAF50]/10 rounded-xl flex items-center justify-center mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#4CAF50" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/>
              </svg>
            </div>
            
            <h2 class="text-2xl font-bold text-gray-800 mb-4">Our Vision</h2>
            
            <p class="text-gray-600 leading-relaxed">
              To become the leading student technology community that produces 
              industry-ready graduates who excel in mobile development, software 
              engineering, and emerging technologies, contributing to Indonesia's 
              digital transformation.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Timeline -->
    <section class="py-16 px-4 bg-white">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12">
          <span class="inline-block px-3 py-1 bg-[#4CAF50]/10 text-[#4CAF50] rounded-full text-sm font-semibold mb-4">
            Our Journey
          </span>
          
          <h2 class="text-3xl font-bold text-gray-800">Timeline of Achievement</h2>
        </div>

        <div class="space-y-8">
          {milestones.map((milestone, index) => (
            <div class="relative flex gap-8">
              <div class="flex flex-col items-center">
                <div class="w-12 h-12 bg-[#4CAF50] rounded-full flex items-center justify-center text-white font-bold text-sm z-10">
                  {milestone.year}
                </div>
                {index < milestones.length - 1 && (
                  <div class="w-0.5 flex-1 bg-gray-200 my-2" />
                )}
              </div>
              
              <div class="flex-1 pb-8">
                <div class="bg-slate-50 rounded-xl p-6 border border-gray-200">
                  <h3 class="text-xl font-bold text-gray-800 mb-2">{milestone.title}</h3>
                  <p class="text-gray-600">{milestone.description}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Organizational Structure -->
    <section class="py-16 px-4">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-12">
          <span class="inline-block px-3 py-1 bg-[#4CAF50]/10 text-[#4CAF50] rounded-full text-sm font-semibold mb-4">
            Organization
          </span>
          
          <h2 class="text-3xl font-bold text-gray-800">Current Leadership</h2>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          {team.map((member) => (
            <div class="bg-white rounded-xl p-6 text-center border border-gray-200 hover:border-[#4CAF50] transition-colors">
              <div class="w-20 h-20 mx-auto mb-4 bg-gradient-to-br from-[#4CAF50]/20 to-[#3DDC84]/20 rounded-full flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#4CAF50" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                  <circle cx="9" cy="7" r="4"/>
                </svg>
              </div>
              
              <div class="inline-block px-2 py-1 bg-[#4CAF50]/10 text-[#4CAF50] rounded-full text-xs font-semibold mb-2">
                {member.role}
              </div>
              
              <h3 class="text-lg font-bold text-gray-800 mb-1">{member.name}</h3>
              
              <p class="text-sm text-gray-500">{member.period}</p>
              
              {member.current && (
                <div class="mt-2 inline-block px-2 py-0.5 bg-green-100 text-green-700 rounded text-xs">
                  Active
                </div>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Location Section -->
    <section class="py-16 px-4 bg-white">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-12">
          <span class="inline-block px-3 py-1 bg-[#4CAF50]/10 text-[#4CAF50] rounded-full text-sm font-semibold mb-4">
            Location
          </span>
          
          <h2 class="text-3xl font-bold text-gray-800">Visit Us</h2>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
          <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden shadow-lg h-[350px]">
            <iframe 
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3965.184555262124!2d106.82348637590873!3d-6.362763762257183!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2e69ec1a90b7b85d%3A0x76f9f05a69e55d5a!2sFaculty%20of%20Engineering%20-%20Universitas%20Indonesia!5e0!3m2!1sen!2sid!4v1709899200000!5m2!1sen!2sid"
              width="100%" 
              height="100%" 
              style="border:0;" 
              allowfullscreen="" 
              loading="lazy" 
              referrerpolicy="no-referrer-when-downgrade"
              title="FT UI Location"
            ></iframe>
          </div>

          <div class="space-y-6">
            <div class="bg-slate-50 rounded-xl p-6 border border-gray-200">
              <h3 class="font-semibold text-gray-800 mb-2 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4CAF50" stroke-width="2">
                  <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
                Address
              </h3>
              <p class="text-gray-600">
                Engineering Center<br/>
                Faculty of Engineering<br/>
                Universitas Indonesia<br/>
                Depok, West Java 16424
              </p>
            </div>

            <div class="bg-slate-50 rounded-xl p-6 border border-gray-200">
              <h3 class="font-semibold text-gray-800 mb-2 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4CAF50" stroke-width="2">
                  <circle cx="12" cy="12" r="10"/>
                  <polyline points="12 6 12 12 16 14"/>
                </svg>
                Meeting Schedule
              </h3>
              <p class="text-gray-600">
                Every Thursday<br/>
                16:00 - 18:00 WIB
              </p>
            </div>

            <a 
              href="https://maps.google.com/?q=Faculty+of+Engineering+Universitas+Indonesia" 
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-[#4CAF50] font-medium hover:underline"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                <polyline points="15 3 21 3 21 9"/>
                <line x1="10" y1="14" x2="21" y2="3"/>
              </svg>
              Get Directions
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Join CTA -->
    <section class="py-16 px-4 bg-gradient-to-br from-[#4CAF50] to-[#3DDC84] text-white">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Want to Join Our Team?</h2>
        
        <p class="text-xl text-white/90 mb-8">
          We're always looking for passionate individuals to help lead the community.
        </p>
        
        <a 
          href="mailto:komandro@ccit-ftui.ac.id" 
          class="inline-flex items-center gap-2 bg-white text-[#4CAF50] px-8 py-4 rounded-xl font-semibold hover:bg-slate-50 transition-colors shadow-lg"
        >
          Contact Us
        </a>
      </div>
    </section>

    <!-- Back to Home -->
    <section class="py-8 px-4 bg-slate-50">
      <div class="max-w-6xl mx-auto">
        <a 
          href="/" 
          class="inline-flex items-center gap-2 text-gray-600 hover:text-[#4CAF50] font-medium transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m15 18-6-6 6-6"/>
          </svg>
          Back to Home
        </a>
      </div>
    </section>
  </main>
</Layout>
