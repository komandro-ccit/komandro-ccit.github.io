---
import Layout from '../layouts/Layout.astro';
import { link } from '../utils/link';
import aboutData from '../data/about.json';

const { milestones, team, roleColors } = aboutData;
---

<Layout title="About - Komandro CCIT-FTUI">
  <main class="pt-24">
    
    <!-- Hero Section -->
    <section class="relative overflow-hidden bg-white hero-pattern border-b border-surface-border">
      <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-32">
        <div class="max-w-4xl">
          <div class="inline-flex items-center gap-3 border border-surface-border px-4 py-2 bg-white rounded-sm mb-10">
            <span class="w-2 h-2 bg-primary"></span>
            <span class="text-secondary font-label-md text-label-md uppercase tracking-widest">Institution</span>
          </div>
          <h1 class="text-headline-xl-home-mobile md:text-headline-xl-home text-on-background mb-6 leading-tight">
            About <span class="text-primary">Komandro</span>
          </h1>
          <p class="text-body-lg-home text-secondary mb-12 max-w-2xl leading-relaxed">
            Learn about our journey, mission, and the community we've built since 2015. We are dedicated to cultivating the next generation of technology professionals.
          </p>
        </div>
      </div>
    </section>

    <!-- Mission & Vision -->
    <section class="py-32 bg-surface-container-low border-b border-surface-border">
      <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
        <div class="mb-20">
          <h2 class="text-headline-lg-home text-on-background mb-6">Mission & Vision</h2>
          <div class="w-24 h-1 bg-primary mb-8"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-16">
          <!-- Mission -->
          <div class="group border-l-4 border-surface-border hover:border-primary pl-8 transition-colors duration-300">
            <i class="bx bx-target-lock text-on-background text-4xl mb-6 font-light"></i>
            <h3 class="text-headline-md-home mb-4 text-on-background">Our Mission</h3>
            <p class="text-secondary text-body-md leading-relaxed">
              To foster a collaborative learning environment where students can develop 
              technical skills in Android development and modern technologies, while 
              building lasting professional networks and contributing to the tech community.
            </p>
          </div>
          <!-- Vision -->
          <div class="group border-l-4 border-surface-border hover:border-primary pl-8 transition-colors duration-300">
            <i class="bx bx-star text-on-background text-4xl mb-6 font-light"></i>
            <h3 class="text-headline-md-home mb-4 text-on-background">Our Vision</h3>
            <p class="text-secondary text-body-md leading-relaxed">
              To become the leading student technology community that produces 
              industry-ready graduates who excel in mobile development, software 
              engineering, and emerging technologies, contributing to Indonesia's 
              digital transformation.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Timeline -->
    <section class="py-32 bg-white border-b border-surface-border">
      <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
        <div class="mb-20">
          <h2 class="text-headline-lg-home text-on-background mb-6">Timeline of Achievement</h2>
          <div class="w-24 h-1 bg-primary mb-8"></div>
        </div>

        <div class="space-y-0">
          {milestones.map((milestone, index) => (
            <div class="relative flex gap-8 border-t border-surface-border py-10">
              <div class="w-24 flex-shrink-0">
                <span class="font-label-md text-label-md text-on-background uppercase tracking-widest">{milestone.year}</span>
              </div>
              <div class="flex-1">
                <h3 class="text-headline-md-home text-on-background mb-2">{milestone.title}</h3>
                <p class="text-secondary text-body-md leading-relaxed">{milestone.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Organizational Structure -->
    <section class="py-32 bg-surface-container-low border-b border-surface-border">
      <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
        <div class="mb-20">
          <h2 class="text-headline-lg-home text-on-background mb-6">Current Leadership</h2>
          <div class="w-24 h-1 bg-primary mb-8"></div>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          {team.map((member) => (
            <div class="bg-white border border-surface-border rounded p-6 text-center hover:border-primary transition-colors duration-300">
              <div class="w-20 h-20 mx-auto mb-4 bg-surface-container flex items-center justify-center">
                <i class="bx bx-user text-on-background text-[32px]"></i>
              </div>
              
              <span class:list={[
                'inline-block px-3 py-1 font-label-md text-label-md uppercase tracking-widest mb-3',
                roleColors[member.role] || 'bg-surface-variant text-on-background'
              ]}>
                {member.role}
              </span>
              
              <h3 class="text-headline-md text-on-background mb-1">{member.name}</h3>
              <p class="text-secondary text-body-md">{member.period}</p>
              
              {member.current && (
                <div class="mt-3 inline-block px-3 py-1 border border-primary text-primary font-label-md text-label-md uppercase tracking-widest">
                  Active
                </div>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Location Section -->
    <section class="py-32 bg-white border-b border-surface-border">
      <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
        <div class="flex flex-col lg:flex-row justify-between items-start gap-16">
          <div class="lg:w-1/3">
            <h2 class="text-headline-lg-home text-on-background mb-6">Visit Us</h2>
            <div class="w-24 h-1 bg-primary mb-8"></div>
            <p class="text-secondary text-body-md leading-relaxed mb-8">
              Komandro is headquartered within the Faculty of Engineering at Universitas Indonesia, providing a premier academic environment for technological advancement.
            </p>
            <a href="https://maps.google.com/?q=Faculty+of+Engineering+Universitas+Indonesia" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-3 text-on-background font-label-md text-label-md uppercase tracking-wider hover:text-primary transition-colors duration-300 group">
              <i class="bx bx-right-arrow-alt text-[20px] group-hover:translate-x-1 transition-transform"></i>
              View on Map
            </a>
          </div>
          <div class="lg:w-2/3 w-full">
            <div class="border border-surface-border overflow-hidden rounded h-[350px] mb-12">
              <iframe 
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3965.184555262124!2d106.82348637590873!3d-6.362763762257183!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2e69ec1a90b7b85d%3A0x76f9f05a69e55d5a!2sFaculty%20of%20Engineering%20-%20Universitas%20Indonesia!5e0!3m2!1sen!2sid!4v1709899200000!5m2!1sen!2sid"
                width="100%" 
                height="100%" 
                style="border:0;" 
                allowfullscreen="" 
                loading="lazy" 
                referrerpolicy="no-referrer-when-downgrade"
                title="FT UI Location"
              ></iframe>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
              <div class="border-t border-surface-border pt-6">
                <h4 class="font-label-md text-label-md text-secondary uppercase tracking-widest mb-2">Address</h4>
                <p class="text-headline-md-home text-on-background mb-2">Engineering Center</p>
                <p class="text-secondary text-body-md leading-relaxed">
                  Faculty of Engineering<br/>Universitas Indonesia<br/>Depok, West Java 16424
                </p>
              </div>
              <div class="border-t border-surface-border pt-6">
                <h4 class="font-label-md text-label-md text-secondary uppercase tracking-widest mb-2">Meeting Schedule</h4>
                <p class="text-headline-md-home text-on-background mb-2">Weekly Assembly</p>
                <p class="text-secondary text-body-md leading-relaxed">
                  Every Thursday<br/>16:00 - 18:00 WIB
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Join CTA -->
    <section class="py-32 bg-on-background text-white">
      <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop text-center">
        <h2 class="text-headline-lg-home mb-6">Want to Join Our Team?</h2>
        <div class="w-24 h-1 bg-primary mx-auto mb-8"></div>
        <p class="text-body-lg-home text-white/70 mb-4 max-w-2xl mx-auto leading-relaxed">
          Membership is open to active students of CCIT - FTUI.
        </p>
        <p class="text-body-lg-home text-white/70 mb-12 max-w-2xl mx-auto leading-relaxed">
          Reach out to us on Instagram to learn more about recruitment and how to get involved.
        </p>
        <a 
          href="https://instagram.com/komandro_ccit" 
          target="_blank" 
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-white text-on-background px-8 py-4 rounded font-label-md text-label-md uppercase tracking-wider hover:bg-primary hover:text-white transition-colors duration-300"
        >
          @komandro_ccit
          <i class="bx bx-right-arrow-alt text-[20px]"></i>
        </a>
      </div>
    </section>
  </main>
</Layout>
