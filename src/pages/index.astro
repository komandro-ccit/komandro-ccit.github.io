---
import Layout from '../layouts/Layout.astro';
import { link } from '../utils/link';

const currentYear = new Date().getFullYear();
const yearsActive = currentYear - 2015;
---

<Layout title="Komandro | CCIT-FTUI Android & Technology Community">
  <main class="pt-24">
    {/* Hero Section */}
    <section class="relative min-h-[80vh] flex items-center justify-center overflow-hidden bg-white hero-pattern border-b border-surface-border">
      <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop relative z-10 w-full py-32">
        <div class="max-w-4xl">
          <div class="inline-flex items-center gap-3 border border-surface-border px-4 py-2 bg-white rounded-sm mb-10">
            <span class="w-2 h-2 bg-primary animate-pulse"></span>
            <span class="text-secondary font-label-md text-label-md uppercase tracking-widest">Est. 2015 &bull; Engineering Excellence</span>
          </div>
          <h1 class="text-headline-xl-home-mobile md:text-headline-xl-home text-on-background mb-6 leading-tight">
            Cultivating the Next Generation of <span class="text-primary">Technology Leaders</span>
          </h1>
          <p class="text-body-lg-home text-secondary mb-12 max-w-2xl leading-relaxed">
            Komunitas Android &amp; Teknologi CCIT-FTUI. We are an institution dedicated to advancing software engineering practice, fostering innovation, and building a prestigious network of technology professionals.
          </p>
          <div class="flex flex-col sm:flex-row gap-6">
            <a href={link('/material')} class="inline-flex items-center justify-center gap-2 bg-on-background text-white px-8 py-4 rounded font-label-md text-label-md uppercase tracking-wider hover:bg-primary hover:text-white transition-colors duration-300">
              Explore Programs
              <i class="bx bx-right-arrow-alt text-[20px]"></i>
            </a>
            <a href={link('/alumni')} class="inline-flex items-center justify-center gap-2 bg-white text-on-background border-2 border-on-background px-8 py-4 rounded font-label-md text-label-md uppercase tracking-wider hover:bg-surface-variant transition-colors duration-300">
              View Hall of Fame
            </a>
          </div>
        </div>
      </div>
    </section>

    {/* Stats Section */}
    <section class="py-32 bg-surface-container-low border-b border-surface-border">
      <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
        <div class="mb-20">
          <h2 class="text-headline-lg-home text-on-background mb-6">Institutional Impact</h2>
          <div class="w-24 h-1 bg-primary mb-8"></div>
          <p class="text-secondary max-w-3xl text-body-lg-home leading-relaxed">
            A decade of sustained excellence in technical education, practical engineering, and community building at Universitas Indonesia.
          </p>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-12 border-t border-surface-border pt-16">
          <div>
            <div class="text-on-background text-headline-xl-home-mobile md:text-headline-xl-home mb-4 font-light tracking-tighter">{yearsActive}+</div>
            <div class="font-label-md text-label-md text-secondary uppercase tracking-widest">Years of Excellence</div>
          </div>
          <div>
            <div class="text-on-background text-headline-xl-home-mobile md:text-headline-xl-home mb-4 font-light tracking-tighter">500+</div>
            <div class="font-label-md text-label-md text-secondary uppercase tracking-widest">Prestigious Alumni</div>
          </div>
          <div>
            <div class="text-on-background text-headline-xl-home-mobile md:text-headline-xl-home mb-4 font-light tracking-tighter">50+</div>
            <div class="font-label-md text-label-md text-secondary uppercase tracking-widest">Technical Workshops</div>
          </div>
          <div>
            <div class="text-on-background text-headline-xl-home-mobile md:text-headline-xl-home mb-4 font-light tracking-tighter">100+</div>
            <div class="font-label-md text-label-md text-secondary uppercase tracking-widest">Engineering Projects</div>
          </div>
        </div>
      </div>
    </section>

    {/* Core Pillars Section */}
    <section class="py-32 bg-white border-b border-surface-border">
      <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
        <div class="mb-20">
          <h2 class="text-headline-lg-home text-on-background mb-6">Core Pillars of Excellence</h2>
          <div class="w-24 h-1 bg-primary mb-8"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-16">
          {/* Pillar 1 */}
          <div class="group border-l-4 border-surface-border hover:border-primary pl-8 transition-colors duration-300">
            <i class="bx bx-trophy text-on-background text-4xl mb-6 font-light"></i>
            <h3 class="text-headline-md-home mb-4 text-on-background">Competitive Engineering</h3>
            <p class="text-secondary text-body-md leading-relaxed">
              Multiple national and international competition victories demonstrating exceptional capability in mobile development and software engineering.
            </p>
          </div>
          {/* Pillar 2 */}
          <div class="group border-l-4 border-surface-border hover:border-primary pl-8 transition-colors duration-300">
            <i class="bx bx-briefcase text-on-background text-4xl mb-6 font-light"></i>
            <h3 class="text-headline-md-home mb-4 text-on-background">Professional Trajectory</h3>
            <p class="text-secondary text-body-md leading-relaxed">
              Alumni establishing distinguished careers at top global technology firms and innovative startups, carrying forward the institution's rigor.
            </p>
          </div>
          {/* Pillar 3 */}
          <div class="group border-l-4 border-surface-border hover:border-primary pl-8 transition-colors duration-300">
            <i class="bx bx-handshake text-on-background text-4xl mb-6 font-light"></i>
            <h3 class="text-headline-md-home mb-4 text-on-background">Industry Integration</h3>
            <p class="text-secondary text-body-md leading-relaxed">
              Strategic partnerships with leading technology enterprises facilitating advanced research, internships, and curriculum development.
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* Location Directory Section */}
    <section class="py-32 bg-surface-container-low border-b border-surface-border">
      <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
        <div class="flex flex-col lg:flex-row justify-between items-start gap-16">
          <div class="lg:w-1/3">
            <h2 class="text-headline-lg-home text-on-background mb-6">Institutional Directory</h2>
            <div class="w-24 h-1 bg-primary mb-8"></div>
            <p class="text-secondary text-body-md leading-relaxed mb-8">
              Komandro is headquartered within the Faculty of Engineering at Universitas Indonesia, providing a premier academic environment for technological advancement.
            </p>
            <a href="https://maps.google.com/?q=Faculty+of+Engineering+Universitas+Indonesia" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-3 text-on-background font-label-md text-label-md uppercase tracking-wider hover:text-primary transition-colors duration-300 group">
              <i class="bx bx-right-arrow-alt text-[20px] group-hover:translate-x-1 transition-transform"></i>
              View on Map
            </a>
          </div>
          <div class="lg:w-2/3 grid grid-cols-1 md:grid-cols-2 gap-x-16 gap-y-12 w-full">
            <div class="border-t border-surface-border pt-6">
              <h4 class="font-label-md text-label-md text-secondary uppercase tracking-widest mb-2">Campus Location</h4>
              <p class="text-headline-md-home text-on-background mb-2">Engineering Center</p>
              <p class="text-secondary text-body-md leading-relaxed">
                Faculty of Engineering<br/>Universitas Indonesia<br/>Depok, West Java 16424
              </p>
            </div>
            <div class="border-t border-surface-border pt-6">
              <h4 class="font-label-md text-label-md text-secondary uppercase tracking-widest mb-2">Facility</h4>
              <p class="text-headline-md-home text-on-background mb-2">Computer Laboratory</p>
              <p class="text-secondary text-body-md leading-relaxed">
                Level 2<br/>Engineering Center Building
              </p>
            </div>
            <div class="border-t border-surface-border pt-6 md:col-span-2">
              <h4 class="font-label-md text-label-md text-secondary uppercase tracking-widest mb-2">Official Convening</h4>
              <p class="text-headline-md-home text-on-background mb-2">Weekly Assembly</p>
              <p class="text-secondary text-body-md leading-relaxed">
                Thursdays, 16:00 - 18:00 WIB
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* Hall of Fame Section */}
    <section class="py-32 bg-white">
      <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
        <div class="flex flex-col md:flex-row justify-between items-end mb-20 gap-8">
          <div>
            <h2 class="text-headline-lg-home text-on-background mb-6">Hall of Fame</h2>
            <div class="w-24 h-1 bg-primary mb-8"></div>
            <p class="text-secondary max-w-2xl text-body-lg-home leading-relaxed">
              Recognizing the distinguished professionals who have defined the legacy of Komandro since our inception.
            </p>
          </div>
          <div class="flex gap-4">
            <button class="px-6 py-3 border-b-2 border-on-background font-label-md text-label-md uppercase tracking-wider text-on-background">Recent</button>
            <button class="px-6 py-3 border-b-2 border-transparent hover:border-surface-border font-label-md text-label-md uppercase tracking-wider text-secondary transition-colors">By Batch</button>
            <button class="px-6 py-3 border-b-2 border-transparent hover:border-surface-border font-label-md text-label-md uppercase tracking-wider text-secondary transition-colors">By Industry</button>
          </div>
        </div>
        
        {/* Structured List */}
        <div class="divide-y divide-surface-border border-t border-b border-surface-border mb-16">
          <div class="py-8 flex flex-col md:flex-row justify-between items-start md:items-center gap-6 hover:bg-surface-container-low transition-colors px-4 -mx-4">
            <div class="flex-1">
              <h4 class="text-headline-md-home text-on-background mb-1">Senior Software Engineer</h4>
              <p class="text-secondary text-body-md">Leading architecture at top regional technology firm.</p>
            </div>
            <div class="flex flex-col md:items-end gap-2">
              <span class="font-label-md text-label-md text-on-background uppercase tracking-widest bg-surface-variant px-4 py-1">Batch 2021</span>
              <span class="text-secondary text-sm">Engineering Div.</span>
            </div>
          </div>
          <div class="py-8 flex flex-col md:flex-row justify-between items-start md:items-center gap-6 hover:bg-surface-container-low transition-colors px-4 -mx-4">
            <div class="flex-1">
              <h4 class="text-headline-md-home text-on-background mb-1">Lead Product Designer</h4>
              <p class="text-secondary text-body-md">Developing accessible design systems for global fintech.</p>
            </div>
            <div class="flex flex-col md:items-end gap-2">
              <span class="font-label-md text-label-md text-on-background uppercase tracking-widest bg-surface-variant px-4 py-1">Batch 2022</span>
              <span class="text-secondary text-sm">Design Div.</span>
            </div>
          </div>
          <div class="py-8 flex flex-col md:flex-row justify-between items-start md:items-center gap-6 hover:bg-surface-container-low transition-colors px-4 -mx-4">
            <div class="flex-1">
              <h4 class="text-headline-md-home text-on-background mb-1">Principal Data Scientist</h4>
              <p class="text-secondary text-body-md">Applying artificial intelligence to complex agricultural optimization.</p>
            </div>
            <div class="flex flex-col md:items-end gap-2">
              <span class="font-label-md text-label-md text-on-background uppercase tracking-widest bg-surface-variant px-4 py-1">Batch 2020</span>
              <span class="text-secondary text-sm">Research Div.</span>
            </div>
          </div>
        </div>
        
        <div class="text-center">
          <a href={link('/alumni')} class="inline-flex items-center gap-3 text-on-background border border-on-background px-8 py-4 rounded font-label-md text-label-md uppercase tracking-wider hover:bg-on-background hover:text-white transition-all duration-300 group">
            Access Complete Register
            <i class="bx bx-right-arrow-alt transition-transform group-hover:translate-x-1"></i>
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>
