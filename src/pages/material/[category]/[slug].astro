---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';

export async function getStaticPaths() {
  const materials = await getCollection('materials');
  
  return materials
    .filter(m => {
      const slugParts = m.slug.split('/');
      // Only standalone articles (2 parts: category/article.mdx)
      return slugParts.length === 2 && !m.slug.endsWith('/index');
    })
    .map((material) => {
      const slugParts = material.slug.split('/');
      return {
        params: { 
          category: slugParts[0], 
          slug: slugParts[1] 
        },
        props: { material }
      };
    });
}

const { material } = Astro.props;
const { category } = Astro.params;

const { Content } = await material.render();

const difficultyColors: Record<string, string> = {
  'Beginner': 'bg-green-100 text-green-800',
  'Intermediate': 'bg-yellow-100 text-yellow-800',
  'Advanced': 'bg-red-100 text-red-800',
};
---

<Layout title={`${material.data.title} - Komandro CCIT-FTUI`}>
  <main class="min-h-screen bg-slate-50">
    
    <!-- Hero Section -->
    <section class="bg-gradient-to-br from-[#4CAF50] to-[#3DDC84] text-white py-12 px-4">
      <div class="max-w-4xl mx-auto">
        <a href={`/material/${category}`} class="inline-flex items-center gap-2 text-white/80 hover:text-white mb-6 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="m15 18-6-6 6-6"/>
          </svg>
          Back to {category}
        </a>
        
        <div class="flex flex-wrap items-center gap-3 mb-4">
          <span class:list={[
            'px-3 py-1 rounded-full text-sm font-medium',
            difficultyColors[material.data.difficulty] || 'bg-white/20'
          ]}>
            {material.data.difficulty}
          </span>
        </div>
        
        <h1 class="text-3xl md:text-4xl font-bold mb-4">{material.data.title}</h1>
        
        <p class="text-lg text-white/90 mb-6">{material.data.description}</p>
        
        <div class="flex flex-wrap items-center gap-6 text-sm">
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/>
              <circle cx="12" cy="7" r="4"/>
            </svg>
            {material.data.author}
          </div>
          
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect width="18" height="18" x="3" y="4" rx="2" ry="2"/>
              <line x1="16" x2="16" y1="2" y2="6"/>
              <line x1="8" x2="8" y1="2" y2="6"/>
              <line x1="3" x2="21" y1="10" y2="10"/>
            </svg>
            {new Date(material.data.pubDate).toLocaleDateString('id-ID', { 
              year: 'numeric', 
              month: 'long', 
              day: 'numeric' 
            })}
          </div>
          
          {material.data.estimatedTime && (
            <div class="flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
              {material.data.estimatedTime}
            </div>
          )}
        </div>
      </div>
    </section>

    <!-- Content -->
    <section class="py-12 px-4">
      <div class="max-w-4xl mx-auto">
        <div class="bg-white rounded-2xl border border-gray-200 p-8 md:p-12">
          {material.data.prerequisites && material.data.prerequisites.length > 0 && (
            <div class="mb-8 p-6 bg-slate-50 rounded-xl border border-gray-200">
              <h3 class="font-semibold text-gray-800 mb-3">Prerequisites</h3>
              <ul class="space-y-2">
                {material.data.prerequisites.map((prereq) => (
                  <li class="flex items-center gap-2 text-gray-600">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4CAF50" stroke-width="2">
                      <polyline points="9 11 12 14 22 4"/>
                      <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
                    </svg>
                    {prereq}
                  </li>
                ))}
              </ul>
            </div>
          )}

          <article class="prose prose-lg max-w-none 
            prose-headings:text-gray-800 
            prose-headings:font-bold
            prose-h1:text-3xl prose-h1:mb-6 prose-h1:mt-8
            prose-h2:text-2xl prose-h2:mb-4 prose-h2:mt-8
            prose-h3:text-xl prose-h3:mb-3 prose-h3:mt-6
            prose-h4:text-lg prose-h4:mb-2 prose-h4:mt-4
            prose-p:text-gray-600 prose-p:mb-4
            prose-a:text-[#4CAF50] prose-a:no-underline hover:prose-a:underline
            prose-strong:text-gray-800 prose-strong:font-semibold
            prose-ul:list-disc prose-ul:ml-6 prose-ul:mb-4
            prose-ol:list-decimal prose-ol:ml-6 prose-ol:mb-4
            prose-li:text-gray-600 prose-li:mb-1
            prose-table:w-full prose-table:border-collapse prose-table:mb-6
            prose-th:bg-gray-100 prose-th:text-gray-800 prose-th:font-semibold prose-th:p-3 prose-th:text-left prose-th:border prose-th:border-gray-200
            prose-td:p-3 prose-td:border prose-td:border-gray-200 prose-td:text-gray-600
            prose-blockquote:border-l-4 prose-blockquote:border-[#4CAF50] prose-blockquote:bg-slate-50 prose-blockquote:pl-4 prose-blockquote:py-2 prose-blockquote:pr-4 prose-blockquote:rounded-r-lg prose-blockquote:mb-6
            prose-img:rounded-lg prose-img:border prose-img:border-gray-200 prose-img:mb-6
            prose-hr:border-gray-200 prose-hr:my-8">
            <Content />
          </article>

          {material.data.tags && material.data.tags.length > 0 && (
            <div class="mt-12 pt-8 border-t border-gray-200">
              <h3 class="text-sm font-semibold text-gray-500 mb-3">Tags</h3>
              <div class="flex flex-wrap gap-2">
                {material.data.tags.map((tag) => (
                  <span class="px-3 py-1 bg-gray-100 text-gray-700 rounded-full text-sm">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          )}
        </div>
      </div>
    </section>
  </main>
</Layout>

<style is:global>
  /* Style untuk inline code (bukan di dalam code block) */
  .prose :not(pre) > code {
    color: #4CAF50;
    background-color: #f3f4f6;
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
    font-size: 0.875rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  }
</style>
