---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import SingleMaterialCard from '../../../components/material/SingleMaterialCard.astro';
import SeriesMaterialCard from '../../../components/material/SeriesMaterialCard.astro';
import MaterialIcon from '../../../components/material/MaterialIcon.astro';
import { link } from '../../../utils/link';

export async function getStaticPaths() {
  const categories = ['web', 'mobile', 'ui-ux', 'qa', 'devops', 'game'];
  return categories.map(cat => ({ params: { category: cat } }));
}

const categoryInfo: Record<string, { name: string; description: string; icon: string }> = {
  'web': {
    name: 'Web Development',
    description: 'Build robust, responsive applications for the browser.',
    icon: 'bx-globe'
  },
  'mobile': {
    name: 'Mobile Development',
    description: 'Create native and cross-platform applications for smartphones.',
    icon: 'bx-mobile-alt'
  },
  'ui-ux': {
    name: 'UI/UX Design',
    description: 'Master layout, color theory, typography, and user research.',
    icon: 'bx-paint'
  },
  'qa': {
    name: 'Quality Assurance',
    description: 'Ensure software reliability through rigorous testing.',
    icon: 'bx-bug'
  },
  'devops': {
    name: 'DevOps',
    description: 'Streamline development with CI/CD and cloud infrastructure.',
    icon: 'bx-cloud'
  },
  'game': {
    name: 'Game Development',
    description: 'Design and program interactive entertainment experiences.',
    icon: 'bx-game'
  }
};

const { category } = Astro.params;
const info = categoryInfo[category] || { 
  name: category, 
  description: '', 
  icon: 'bx-book'
};

const allMaterials = await getCollection('materials');

// Get materials for this category
const categoryMaterials = allMaterials.filter(m => 
  m.slug.startsWith(category + '/')
);

// Group materials
const curriculums: typeof categoryMaterials = [];
const standaloneArticles: typeof categoryMaterials = [];
const curriculumLessons: Record<string, typeof categoryMaterials> = {};

categoryMaterials.forEach(material => {
  const slugParts = material.slug.split('/');
  const isCurriculum = material.data.type === 'curriculum';
  
  if (isCurriculum) {
    curriculums.push(material);
  } else if (slugParts.length === 2) {
    standaloneArticles.push(material);
  } else if (slugParts.length >= 3) {
    const curriculumName = slugParts[1];
    if (!curriculumLessons[curriculumName]) {
      curriculumLessons[curriculumName] = [];
    }
    curriculumLessons[curriculumName].push(material);
  }
});

// Sort curriculum lessons by order
Object.keys(curriculumLessons).forEach(key => {
  curriculumLessons[key].sort((a, b) => (a.data.order || 0) - (b.data.order || 0));
});

const totalItems = curriculums.length + standaloneArticles.length;
---

<Layout title={`${info.name} - Materials - Komandro CCIT-FTUI`}>
  <main class="min-h-screen bg-surface-light pt-24">
    
    {/* Hero Section */}
    <section class="relative py-32 overflow-hidden bg-white border-b border-surface-border hero-pattern">
      <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop relative z-10">
        <div class="max-w-4xl">
          <a href={link('/material')} class="inline-flex items-center gap-2 text-secondary hover:text-on-background mb-6 font-label-md text-label-md uppercase tracking-wider transition-colors">
            <MaterialIcon name="bx-arrow-back" class="text-[18px]" />
            Back to Pathways
          </a>
          
          <div class="flex items-center gap-3 mb-6">
            <i class={`bx ${info.icon} text-on-background text-[40px]`}></i>
          </div>
          
          <h1 class="text-headline-xl-home-mobile md:text-headline-xl-home text-on-background mb-4 leading-tight">
            {info.name}
          </h1>
          <p class="text-body-lg-home text-secondary max-w-2xl mb-8 leading-relaxed">
            {info.description}
          </p>
          
          <div class="flex gap-4">
            <div class="px-4 py-2 bg-surface-variant text-on-background font-label-md text-label-md uppercase tracking-widest">
              <span class="font-bold">{curriculums.length}</span> Series
            </div>
            <div class="px-4 py-2 bg-surface-variant text-on-background font-label-md text-label-md uppercase tracking-widest">
              <span class="font-bold">{standaloneArticles.length}</span> Articles
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* Content */}
    <section class="py-16 px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
      
      {/* Series Section */}
      {curriculums.length > 0 && (
        <div class="mb-16">
          <div class="flex items-center gap-3 mb-8">
            <MaterialIcon name="bx-collection" class="text-3xl text-primary" />
            <h2 class="font-headline-lg text-headline-lg text-on-surface">Structured Series</h2>
            <div class="flex-1 h-px bg-outline-variant" />
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-md">
            {curriculums.map((curriculum) => {
              const slugParts = curriculum.slug.split('/');
              const curriculumSlug = slugParts[slugParts.length - 1];
              const lessons = curriculumLessons[curriculumSlug] || [];
              const lessonTitles = lessons.slice(0, 4).map(l => l.data.title);
              
              return (
                <SeriesMaterialCard
                  href={link(`/material/${category}/${curriculumSlug}`)}
                  title={curriculum.data.title}
                  description={curriculum.data.description}
                  moduleCount={lessons.length}
                  modules={lessonTitles}
                  difficulty={curriculum.data.difficulty}
                />
              );
            })}
          </div>
        </div>
      )}

      {/* Single Articles Section */}
      {standaloneArticles.length > 0 && (
        <div class:list={[curriculums.length > 0 ? 'border-t-4 border-surface-variant pt-16' : '']}>
          <div class="flex items-center gap-3 mb-8">
            <MaterialIcon name="bx-file" class="text-3xl text-primary" />
            <h2 class="font-headline-lg text-headline-lg text-on-surface">Single Articles</h2>
            <div class="flex-1 h-px bg-outline-variant" />
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-md">
            {standaloneArticles.map((article) => {
              const articleSlug = article.slug.split('/').pop()?.replace('.mdx', '');
              return (
                <SingleMaterialCard
                  href={link(`/material/${category}/${articleSlug}`)}
                  title={article.data.title}
                  description={article.data.description}
                  author={article.data.author}
                  date={new Date(article.data.pubDate).toLocaleDateString('id-ID', { month: 'short', year: 'numeric' })}
                  difficulty={article.data.difficulty}
                />
              );
            })}
          </div>
        </div>
      )}

      {totalItems === 0 && (
        <div class="text-center py-24 bg-white border border-surface-border rounded">
          <MaterialIcon name="bx-book-open" class="text-6xl text-on-surface-variant mb-4" />
          <h3 class="font-headline-md text-headline-md text-on-surface mb-2">No Materials Yet</h3>
          <p class="text-on-surface-variant">Materials for this pathway will be added soon!</p>
        </div>
      )}
    </section>
  </main>
</Layout>
