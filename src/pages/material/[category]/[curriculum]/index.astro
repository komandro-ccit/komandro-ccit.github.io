---
import { getCollection } from 'astro:content';
import Layout from '../../../../layouts/Layout.astro';
import MaterialIcon from '../../../../components/material/MaterialIcon.astro';
import SeriesStepper from '../../../../components/material/SeriesStepper.astro';
import { link } from '../../../../utils/link';

export async function getStaticPaths() {
  const materials = await getCollection('materials');
  
  const curriculumSlugs = new Set<string>();
  
  materials.forEach(material => {
    const slugParts = material.slug.split('/');
    if (slugParts.length >= 3) {
      const category = slugParts[0];
      const curriculumName = slugParts[1];
      curriculumSlugs.add(`${category}/${curriculumName}`);
    }
  });
  
  return Array.from(curriculumSlugs).map(slug => {
    const [category, curriculum] = slug.split('/');
    return {
      params: { category, curriculum },
      props: { curriculumSlug: slug }
    };
  });
}

const { category, curriculum } = Astro.params;
const { curriculumSlug } = Astro.props;

const allMaterials = await getCollection('materials');

// Get curriculum index
const curriculumIndex = allMaterials.find(m => 
  m.slug === `${curriculumSlug}/index` || m.slug === curriculumSlug
);

// Get all lessons for this curriculum
const lessons = allMaterials
  .filter(m => {
    const slugParts = m.slug.split('/');
    return slugParts.length === 3 && 
           slugParts[0] === category && 
           slugParts[1] === curriculum &&
           slugParts[2] !== 'index';
  })
  .sort((a, b) => (a.data.order || 0) - (b.data.order || 0));

// Fallback if curriculum index not found
const curriculumData = curriculumIndex?.data || {
  title: curriculum.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase()),
  description: 'Complete learning curriculum',
  difficulty: 'Beginner',
  author: 'Komandro Team',
  estimatedTime: 'TBD',
  pubDate: new Date().toISOString()
};

// Map lessons to modules for stepper
const modules = lessons.map((lesson, index) => ({
  title: lesson.data.title,
  description: lesson.data.description,
  status: index === 0 ? 'active' as const : 'future' as const,
  lessons: [{
    title: lesson.data.title,
    slug: lesson.slug.split('/').pop()?.replace('.mdx', '') || ''
  }]
}));

const activeModuleIndex = 0;
---

<Layout title={`${curriculumData.title} - Komandro CCIT-FTUI`}>
  <main class="min-h-screen bg-surface-light pt-24">
    
    {/* Hero / Back Navigation */}
    <section class="relative py-16 overflow-hidden bg-white border-b border-surface-border hero-pattern">
      <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop relative z-10">
        <a href={link(`/material/${category}`)} class="inline-flex items-center gap-sm text-secondary hover:text-on-background mb-6 transition-colors font-label-md text-label-md uppercase tracking-wider">
          <MaterialIcon name="bx-arrow-back" class="text-[18px]" />
          Back to {category}
        </a>
      </div>
    </section>

    {/* Curriculum Overview Card */}
    <section class="py-8 px-margin-mobile md:px-margin-desktop -mt-8 max-w-container-max mx-auto">
      <div class="max-w-4xl mx-auto">
        <div class="bg-surface-container-lowest border border-surface-variant overflow-hidden rounded">
          <div class="h-2 bg-primary" />
          
          <div class="p-8">
            <div class="flex flex-wrap items-center gap-3 mb-4">
              <span class="bg-primary text-white px-3 py-1 font-label-md text-label-md uppercase tracking-widest">
                Series
              </span>
              
              {curriculumData.difficulty && (
                <span class="px-3 py-1 bg-surface-variant text-on-background font-label-md text-label-md uppercase tracking-widest">
                  {curriculumData.difficulty}
                </span>
              )}
              
              {curriculumData.estimatedTime && (
                <span class="px-3 py-1 bg-surface-variant text-on-background font-label-md text-label-md uppercase tracking-widest flex items-center gap-1">
                  <MaterialIcon name="bx-time" class="text-[14px]" />
                  {curriculumData.estimatedTime}
                </span>
              )}
              
              <span class="px-3 py-1 bg-surface-variant text-on-background font-label-md text-label-md uppercase tracking-widest flex items-center gap-1">
                <MaterialIcon name="bx-book" class="text-[14px]" />
                {lessons.length} Lessons
              </span>
            </div>

            <h1 class="font-headline-xl text-headline-xl text-on-surface mb-4">{curriculumData.title}</h1>
            
            <p class="text-lg text-on-surface-variant mb-6">{curriculumData.description}</p>
            
            <div class="flex items-center gap-4 text-sm text-on-surface-variant mb-6">
              <div class="flex items-center gap-2">
                <MaterialIcon name="bx-user" class="text-[16px]" />
                By {curriculumData.author}
              </div>
              
              <div class="flex items-center gap-2">
                <MaterialIcon name="bx-calendar" class="text-[16px]" />
                {new Date(curriculumData.pubDate).toLocaleDateString('id-ID', { 
                  year: 'numeric', 
                  month: 'long', 
                  day: 'numeric' 
                })}
              </div>
            </div>

            {curriculumData.prerequisites && curriculumData.prerequisites.length > 0 && (
              <div class="bg-surface-container p-4 border border-outline-variant rounded">
                <h4 class="font-label-md text-label-md text-on-surface uppercase tracking-widest mb-2">Prerequisites</h4>
                <ul class="space-y-1">
                  {curriculumData.prerequisites.map((prereq) => (
                    <li class="flex items-center gap-2 text-sm text-on-surface-variant">
                      <MaterialIcon name="bx-check" class="text-primary text-[14px]" />
                      {prereq}
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </div>
        </div>
      </div>
    </section>

    {/* Lessons Stepper */}
    <section class="py-8 px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
      <div class="max-w-4xl mx-auto">
        <div class="flex items-center justify-between mb-8">
          <h2 class="font-headline-lg text-headline-lg text-on-surface">Course Content</h2>
          <span class="text-sm text-on-surface-variant">{lessons.length} Lessons</span>
        </div>

        {lessons.length === 0 ? (
          <div class="bg-surface-container-lowest border border-surface-variant rounded p-12 text-center">
            <MaterialIcon name="bx-edit" class="text-6xl text-on-surface-variant mb-4" />
            <p class="text-on-surface-variant">Lessons will be added soon!</p>
          </div>
        ) : (
          <SeriesStepper 
            modules={modules}
            category={category}
            curriculum={curriculum}
            activeModuleIndex={activeModuleIndex}
          />
        )}
      </div>
    </section>
  </main>
</Layout>
