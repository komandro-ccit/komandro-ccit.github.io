---
import { getCollection } from 'astro:content';
import Layout from '../../../../layouts/Layout.astro';
import ReadingLayout from '../../../../components/material/ReadingLayout.astro';
import { link } from '../../../../utils/link';

export async function getStaticPaths() {
  const materials = await getCollection('materials');
  
  return materials
    .filter(m => {
      const slugParts = m.slug.split('/');
      return slugParts.length === 3 && !m.slug.endsWith('/index');
    })
    .map((material) => {
      const slugParts = material.slug.split('/');
      return {
        params: { 
          category: slugParts[0], 
          curriculum: slugParts[1],
          lesson: slugParts[2]
        },
        props: { material }
      };
    });
}

const { material } = Astro.props;
const { category, curriculum } = Astro.params;

const { Content, headings } = await material.render();

// Get curriculum info
let curriculumInfo = null;
if (curriculum) {
  const allMaterials = await getCollection('materials');
  curriculumInfo = allMaterials.find(m => 
    m.slug === `${category}/${curriculum}/index`
  );
}

const backUrl = `/material/${category}/${curriculum}`;
const backLabel = `Back to ${curriculumInfo?.data.title || curriculum}`;

// Build TOC from h2/h3 headings
const tocItems = headings
  .filter(h => h.depth === 2 || h.depth === 3)
  .map(h => ({
    text: h.text,
    href: `#${h.slug}`
  }));

// Get prev/next lessons for navigation
const allMaterials = await getCollection('materials');
const curriculumLessons = allMaterials
  .filter(m => {
    const parts = m.slug.split('/');
    return parts.length === 3 && parts[0] === category && parts[1] === curriculum && parts[2] !== 'index';
  })
  .sort((a, b) => (a.data.order || 0) - (b.data.order || 0));

const currentIndex = curriculumLessons.findIndex(l => l.slug === material.slug);
const prevLesson = currentIndex > 0 ? curriculumLessons[currentIndex - 1] : null;
const nextLesson = currentIndex < curriculumLessons.length - 1 ? curriculumLessons[currentIndex + 1] : null;

const prevSlug = prevLesson?.slug.split('/').pop()?.replace('.mdx', '');
const nextSlug = nextLesson?.slug.split('/').pop()?.replace('.mdx', '');
---

<Layout title={`${material.data.title} - Komandro CCIT-FTUI`}>
  <ReadingLayout
    title={material.data.title}
    description={material.data.description}
    backUrl={backUrl}
    backLabel={backLabel}
    type="LESSON"
    author={material.data.author}
    pubDate={material.data.pubDate}
    estimatedTime={material.data.estimatedTime}
    tocItems={tocItems}
    prerequisites={material.data.prerequisites}
    tags={material.data.tags}
  >
    <Content />
    
    <div slot="navigation" class="mt-xl pt-lg border-t border-outline-variant flex justify-between items-center">
      <div>
        <p class="font-label-md text-label-md text-on-surface-variant mb-1">Previous</p>
        {prevLesson && prevSlug ? (
          <a href={link(`/material/${category}/${curriculum}/${prevSlug}`)} class="font-headline-md text-headline-md text-primary-m3 hover:underline">
            {prevLesson.data.title}
          </a>
        ) : (
          <span class="font-headline-md text-headline-md text-primary-m3 opacity-50">—</span>
        )}
      </div>
      <div class="text-right">
        <p class="font-label-md text-label-md text-on-surface-variant mb-1">Next</p>
        {nextLesson && nextSlug ? (
          <a href={link(`/material/${category}/${curriculum}/${nextSlug}`)} class="font-headline-md text-headline-md text-primary-m3 hover:underline">
            {nextLesson.data.title}
          </a>
        ) : (
          <span class="font-headline-md text-headline-md text-primary-m3 opacity-50">—</span>
        )}
      </div>
    </div>
  </ReadingLayout>
</Layout>
